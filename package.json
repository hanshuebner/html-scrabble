{
    "name": "html-scrabble",
    "description": "Multi user Scrabble game",
    "version": "0.2.0",
    "private": true,
    "author": {
        "name": "Hans Hübner",
        "email": "hans.huebner@gmail.com",
        "url": "https://github.com/hanshuebner"
    },
    "repository": {
        "type": "git",
        "url": "git://github.com/hanshuebner/html-scrabble.git"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "packageManager": "pnpm@10.12.3",
    "type": "module",
    "license": "MIT/X11",
    "scripts": {
        "dev": "pnpm --filter @scrabble/client dev",
        "dev:server": "pnpm --filter @scrabble/server dev",
        "build": "pnpm -r build",
        "test": "pnpm --filter @scrabble/shared test",
        "test:all": "pnpm -r test",
        "lint": "eslint packages/*/src/",
        "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx}'"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "ejs"
        ]
    },
    "devDependencies": {
        "@eslint/js": "^9.39.3",
        "eslint": "^9.39.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^7.0.1",
        "prettier": "^3.8.1",
        "typescript-eslint": "^8.56.1"
    }
}
